# =========================================================================
# Supabase Configuration (Client-side & General)
# =========================================================================

# Your Supabase Project ID
SUPABASE_PROJECT_ID="your-project-id"

# Your Supabase Project URL
SUPABASE_URL="https://your-project-id.supabase.co"

# Your Supabase Anon/Publishable Key
SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# =========================================================================
# Vite Client-Side Variables
# =========================================================================
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"

# =========================================================================
# Server-Side / Admin Configuration (SECURE)
# =========================================================================
# WARNING: NEVER prefix this key with VITE_ to keep it hidden from browser code.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# =========================================================================
# Lovable AI Gateway Configuration
# =========================================================================
LOVABLE_API_KEY="your-lovable-api-key"
